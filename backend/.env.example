DATABASE_URL=postgresql://user:password@localhost:5432/cams
PORT=5000

# Secret used to sign login tokens (Auth::issueToken). Set this to a long,
# random value in any real deployment — anyone who has it can forge tokens.
APP_SECRET=change-me-to-a-long-random-string

# --- Password reset emails (see src/Mailer.php) ---
# Base URL of the deployed frontend, used to build the link inside a
# password-reset email (e.g. https://cams.example.org). Defaults to
# http://localhost:5173 (the Vite dev server) if unset.
FRONTEND_URL=http://localhost:5173
# Set to "true" to actually attempt sending mail via PHP's mail() function
# (requires a configured MTA/sendmail on the server — most local dev
# machines don't have one). When unset/false, Mailer falls back to writing
# each email to backend/storage/outbox/ instead of sending it, which is
# enough to demo and test the reset flow without any mail server — the
# same idea as Laravel's "log" mail driver for local development.
MAIL_ENABLED=false
MAIL_FROM=no-reply@cams.example.org
